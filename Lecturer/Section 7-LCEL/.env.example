# ============================================================
# .env.example — Copy to .env and fill in your values
# ============================================================

# --- Required ---
GROQ_API_KEY=your_groq_api_key_here

# --- LLM Settings ---
LLM_MODEL=Gemma2-9b-It
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# --- Server Settings ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=2
LOG_LEVEL=info

# --- Application Metadata ---
APP_TITLE=LangChain LLM API Server
APP_VERSION=1.0.0
APP_DESCRIPTION=Production-grade API server using LangChain + LangServe

# --- CORS (comma-separated origins) ---
# Use * for development, restrict to your domain in production
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=*

# --- Rate Limiting ---
RATE_LIMIT_RPM=60
